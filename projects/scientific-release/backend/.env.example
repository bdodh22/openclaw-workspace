# 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# .env 文件已加入 .gitignore，请勿提交到 Git

# ==================== 数据库配置 ====================
DB_USERNAME=sr_user
DB_PASSWORD=你的数据库密码

# ==================== 微信小程序配置 ====================
WECHAT_APPID=wxa914ecc15836bda6
WECHAT_SECRET=你的微信小程序 Secret

# ==================== 服务器配置 ====================
NODE_ENV=production
PORT=3000
HOST=localhost

# ==================== SSL 配置 (可选) ====================
# SSL_CERT_PATH=/etc/letsencrypt/live/sf.dexoconnect.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/sf.dexoconnect.com/privkey.pem
