<!--pages/calendar/calendar.wxml - Stitch Design: 佛历日历-->
<view class="container">
  <!-- Top Navigation -->
  <view class="top-nav">
    <view class="nav-brand">
      <text class="brand-icon">🌿</text>
      <text class="brand-title">生灵守护</text>
    </view>
    <view class="nav-actions">
      <text class="action-icon">🔍</text>
      <text class="action-icon active">📅</text>
    </view>
  </view>

  <!-- Main Content -->
  <view class="main-content">
    <!-- Hero Section: Month Toggle -->
    <view class="month-selector">
      <view class="month-btn" bindtap="prevMonth">‹</view>
      <view class="month-info">
        <text class="month-title">{{currentYear}}年 · {{currentMonth}}月</text>
        <text class="month-subtitle">{{englishMonth}} {{currentYear}}</text>
      </view>
      <view class="month-btn" bindtap="nextMonth">›</view>
    </view>

    <!-- Bento Grid: Today's Info -->
    <view class="today-grid">
      <!-- Main Date Card -->
      <view class="date-card">
        <view class="date-badge">TODAY</view>
        <text class="date-day">{{currentDay}}</text>
        <text class="date-lunar">{{lunarDate}}</text>
        <view class="date-footer">
          <text class="ganzhi">{{ganzhiYear}}年</text>
          <text class="zodiac">属相：{{zodiac}}</text>
        </view>
      </view>

      <!-- Ritual Stack -->
      <view class="ritual-stack">
        <view class="ritual-card vegetarian">
          <text class="ritual-icon">🥬</text>
          <text class="ritual-title">十斋日</text>
          <text class="ritual-subtitle">VEGETARIAN DAY</text>
        </view>
        <view class="ritual-card suitable">
          <view class="suitable-indicator">
            <view class="indicator-dot"></view>
            <text class="indicator-title">今日宜</text>
          </view>
          <text class="suitable-text">戒杀、放生、<br/>祈福、求嗣</text>
        </view>
      </view>
    </view>

    <!-- Avoidance Banner -->
    <view class="avoid-banner">
      <view class="avoid-left">
        <view class="avoid-icon">⛔</view>
        <view class="avoid-info">
          <text class="avoid-title">今日忌</text>
          <text class="avoid-text">开市、入宅、安葬</text>
        </view>
      </view>
      <text class="avoid-info-icon">ℹ</text>
    </view>

    <!-- Calendar List -->
    <view class="calendar-section">
      <text class="section-title">佛历日程</text>
      <view class="calendar-list">
        <!-- Today -->
        <view class="calendar-item today">
          <view class="item-date">
            <text class="weekday">周五</text>
            <text class="day">24</text>
          </view>
          <view class="item-content">
            <view class="item-header">
              <text class="lunar-day">四月十七</text>
              <view class="special-badge">十斋日</view>
            </view>
            <text class="item-desc">护生功德翻倍。宜持咒，行善事。</text>
          </view>
          <text class="check-icon">✓</text>
        </view>

        <!-- Future Days -->
        <view class="calendar-item" bindtap="selectDay" data-day="25">
          <view class="item-date">
            <text class="weekday">周六</text>
            <text class="day">25</text>
          </view>
          <view class="item-content">
            <text class="lunar-day">四月十八</text>
            <text class="item-desc">宜放生麻雀、斑鸠。</text>
          </view>
          <text class="add-icon">+</text>
        </view>

        <view class="calendar-item" bindtap="selectDay" data-day="26">
          <view class="item-date">
            <text class="weekday">周日</text>
            <text class="day">26</text>
          </view>
          <view class="item-content">
            <view class="item-header">
              <text class="lunar-day">四月十九</text>
              <view class="six-badge">六斋日</view>
            </view>
            <text class="item-desc">阳光和煦，利于野外护生巡查。</text>
          </view>
          <text class="add-icon">+</text>
        </view>

        <view class="calendar-item" bindtap="selectDay" data-day="27">
          <view class="item-date">
            <text class="weekday">周一</text>
            <text class="day">27</text>
          </view>
          <view class="item-content">
            <text class="lunar-day">四月二十</text>
            <text class="item-desc">宜整理放生笔记。</text>
          </view>
          <text class="add-icon">+</text>
        </view>
      </view>
    </view>

    <!-- Quote Card -->
    <view class="quote-card">
      <image class="quote-bg" src="/images/calendar/zen-mountain.png" mode="aspectFill" />
      <view class="quote-overlay">
        <text class="quote-text">"诸余罪中，杀业最重；诸功德中，放生第一。"</text>
        <text class="quote-source">— 《大智度论》</text>
      </view>
    </view>
  </view>

  <!-- Bottom Navigation -->
  <view class="bottom-nav">
    <view class="nav-item" bindtap="goToIndex">
      <text class="nav-icon">🏠</text>
      <text class="nav-label">首页</text>
    </view>
    <view class="nav-item active">
      <text class="nav-icon">📊</text>
      <text class="nav-label">物种</text>
    </view>
    <view class="nav-item" bindtap="goToCertificate">
      <text class="nav-icon">🏆</text>
      <text class="nav-label">证书</text>
    </view>
    <view class="nav-item" bindtap="goToProfile">
      <text class="nav-icon">👤</text>
      <text class="nav-label">我的</text>
    </view>
  </view>

  <!-- FAB -->
  <view class="fab" bindtap="addRelease">
    <text class="fab-icon">+</text>
  </view>
</view>
