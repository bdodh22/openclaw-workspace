/* pages/index/index.wxss - Modern Zen Design */

/* ===== 沉浸式首屏 - 动态背景 ===== */
.banner {
  position: relative;
  height: 600rpx;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 动态水墨背景效果 */
.banner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.05) 0%, transparent 50%),
              radial-gradient(circle at 70% 50%, rgba(255,255,255,0.03) 0%, transparent 50%);
  animation: flow 15s ease-in-out infinite;
}

@keyframes flow {
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.1); opacity: 0.8; }
}

.banner-content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx;
}

.banner-title {
  font-size: 56rpx;
  font-weight: 300;
  letter-spacing: 8rpx;
  margin-bottom: 24rpx;
  color: #FFFFFF;
  text-shadow: 0 4rpx 24rpx rgba(0,0,0,0.3);
}

.banner-subtitle {
  font-size: 28rpx;
  font-weight: 300;
  letter-spacing: 2rpx;
  opacity: 0.9;
  color: rgba(255,255,255,0.9);
}

/* 禅语打字机效果 */
.zen-quote {
  margin-top: 48rpx;
  padding: 32rpx 48rpx;
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
  max-width: 600rpx;
}

.zen-text {
  font-size: 32rpx;
  font-weight: 300;
  line-height: 2;
  letter-spacing: 3rpx;
  color: rgba(255,255,255,0.95);
  text-align: center;
  font-style: italic;
}

/* ===== 核心按钮 - 立即放生 ===== */
.btn-release {
  margin-top: 48rpx;
  background: linear-gradient(135deg, var(--accent-gold) 0%, #B8945E 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 32rpx 80rpx;
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: 4rpx;
  box-shadow: 0 12rpx 48rpx rgba(201, 169, 97, 0.4);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.btn-release::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.6s;
}

.btn-release:active::before {
  left: 100%;
}

.btn-release:active {
  transform: translateY(4rpx);
  box-shadow: 0 6rpx 24rpx rgba(201, 169, 97, 0.3);
}

/* ===== 分区标题 - 新中式 ===== */
.section-title {
  font-size: 36rpx;
  font-weight: 300;
  color: var(--text-primary);
  margin-bottom: 32rpx;
  padding-left: 24rpx;
  border-left: 4rpx solid var(--primary-color);
  letter-spacing: 2rpx;
}

/* ===== Bento Grid 布局 ===== */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 32rpx;
}

.bento-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255,255,255,0.8);
  backdrop-filter: blur(10rpx);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 240rpx;
  position: relative;
  overflow: hidden;
}

.bento-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--accent-gold));
  opacity: 0;
  transition: opacity 0.3s;
}

.bento-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-elevated);
}

.bento-card:active::before {
  opacity: 1;
}

/* 大卡片 - 跨两列 */
.bento-card.large {
  grid-column: span 2;
  min-height: 280rpx;
}

.bento-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(74, 93, 78, 0.2));
}

.bento-title {
  font-size: 30rpx;
  font-weight: 400;
  color: var(--text-primary);
  letter-spacing: 2rpx;
  text-align: center;
}

.bento-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  text-align: center;
}

/* 金色强调卡片 */
.bento-card.gold {
  background: linear-gradient(135deg, rgba(201, 169, 97, 0.05) 0%, rgba(201, 169, 97, 0.1) 100%);
  border: 1rpx solid rgba(201, 169, 97, 0.3);
}

.bento-card.gold .bento-icon {
  filter: drop-shadow(0 4rpx 12rpx rgba(201, 169, 97, 0.3));
}

/* ===== 每日智慧 - 禅意卡片 ===== */
.wisdom-section {
  padding: 32rpx;
  margin-top: 16rpx;
}

.wisdom-content {
  background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-secondary) 100%);
  padding: 48rpx 40rpx;
  border-radius: 24rpx;
  border-left: 4rpx solid var(--accent-gold);
  box-shadow: var(--shadow-soft);
  position: relative;
  overflow: hidden;
}

.wisdom-content::before {
  content: '"';
  position: absolute;
  top: 20rpx;
  left: 24rpx;
  font-size: 80rpx;
  color: var(--accent-gold);
  opacity: 0.2;
  font-family: Georgia, serif;
  line-height: 1;
}

.wisdom-text {
  position: relative;
  z-index: 10;
  font-size: 32rpx;
  line-height: 2;
  color: var(--text-primary);
  font-style: italic;
  text-align: center;
  letter-spacing: 2rpx;
}

.wisdom-source {
  margin-top: 24rpx;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-secondary);
  font-style: normal;
}

/* ===== 公告栏 - 简约风格 ===== */
.notice-section {
  padding: 32rpx;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 28rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  box-shadow: var(--shadow-soft);
  border-left: 4rpx solid var(--accent-gold);
  transition: all 0.3s;
}

.notice-item:active {
  transform: scale(0.99);
  box-shadow: var(--shadow-elevated);
}

.notice-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 2rpx 8rpx rgba(201, 169, 97, 0.3));
}

.notice-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
  flex: 1;
}

.notice-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--text-hint);
}

/* ===== 快速操作 - 旧样式兼容 ===== */
.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 32rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 16rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  box-shadow: var(--shadow-soft);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.action-item:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-elevated);
  background: linear-gradient(135deg, rgba(74, 93, 78, 0.05) 0%, rgba(74, 93, 78, 0.1) 100%);
}

.action-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(74, 93, 78, 0.15));
}

.action-text {
  font-size: 24rpx;
  color: var(--text-primary);
}

/* ===== 容器 ===== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  padding-bottom: 48rpx;
}

/* ===== 动画效果 ===== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in {
  animation: fadeInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.animate-delay-1 { animation-delay: 0.1s; }
.animate-delay-2 { animation-delay: 0.2s; }
.animate-delay-3 { animation-delay: 0.3s; }
.animate-delay-4 { animation-delay: 0.4s; }
