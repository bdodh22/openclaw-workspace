/* pages/index/index.wxss */

.banner {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
  padding: 48rpx 32rpx;
}

.banner-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.banner-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.banner-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #4CAF50;
}

/* Quick Actions */
.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  transition: background 0.2s;
}

.action-item:active {
  background: #e8f5e9;
}

.action-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

/* Daily Wisdom */
.wisdom-content {
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
  padding: 32rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #ff9800;
}

.wisdom-text {
  font-size: 32rpx;
  line-height: 1.8;
  color: #5d4037;
  font-style: italic;
}

/* Notice Board */
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: #fff3e0;
  border-radius: 12rpx;
  border-left: 4rpx solid #ff9800;
}

.notice-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}
