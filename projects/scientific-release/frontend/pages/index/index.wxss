/* pages/index/index.wxss */

.banner {
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  padding: 60rpx 32rpx;
  text-align: center;
}

.banner-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.banner-subtitle {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #2E7D32;
}

/* Quick Actions Grid */
.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  transition: background-color 0.2s;
}

.action-item:active {
  background: #E8F5E9;
}

.action-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666666;
  text-align: center;
}

/* Daily Wisdom */
.wisdom-content {
  background: #FFF8E1;
  padding: 32rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #FF9800;
}

.wisdom-text {
  font-size: 32rpx;
  color: #5D4037;
  line-height: 1.8;
}

/* Notice Board */
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #FFF3E0;
  border-radius: 12rpx;
}

.notice-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 28rpx;
  color: #E65100;
  line-height: 1.6;
  flex: 1;
}
