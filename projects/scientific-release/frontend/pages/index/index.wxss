/* pages/index/index.wxss - Stitch Design: Bento Grid */

.container {
  min-height: 100vh;
  background: var(--surface);
  padding-bottom: 160rpx;
}

.main-content {
  padding: var(--spacing-xxl) var(--spacing-lg);
  padding-top: 140rpx;
}

/* ===== Daily Wisdom Section ===== */
.wisdom-section {
  margin-bottom: var(--spacing-xxl);
}

.wisdom-card {
  position: relative;
  overflow: hidden;
  padding: var(--spacing-xxl);
  background: var(--surface-container);
  border-radius: var(--radius-xxl);
  box-shadow: var(--shadow-inset);
}

.wisdom-quote-icon {
  position: absolute;
  top: var(--spacing-md);
  right: var(--spacing-md);
  font-size: 80rpx;
  color: var(--primary);
  opacity: 0.1;
  font-family: var(--font-headline);
}

.wisdom-label {
  display: block;
  font-family: var(--font-label);
  font-size: 20rpx;
  color: var(--primary);
  opacity: 0.6;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: var(--spacing-md);
}

.wisdom-text {
  display: block;
  font-family: var(--font-headline);
  font-size: 36rpx;
  line-height: 1.8;
  color: var(--on-surface);
  opacity: 0.9;
  font-style: italic;
  min-height: 160rpx;
}

.wisdom-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: var(--spacing-lg);
  padding-top: var(--spacing-md);
  border-top: 1rpx solid rgba(195, 200, 193, 0.1);
}

.wisdom-date {
  font-family: var(--font-label);
  font-size: 20rpx;
  color: var(--primary);
  opacity: 0.4;
  letter-spacing: 2rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-family: var(--font-label);
  font-size: 24rpx;
  font-weight: 500;
  color: var(--primary);
}

.arrow-icon {
  font-size: 28rpx;
  transition: transform 0.3s;
}

.share-btn:active .arrow-icon {
  transform: translateX(8rpx);
}

/* ===== Bento Grid ===== */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.bento-card {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-xxl);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.bento-card:active {
  transform: scale(0.98);
}

.bento-large {
  grid-column: span 2;
}

/* Species Card (Large) */
.species-card {
  height: 448rpx;
  background: var(--primary-container);
  color: var(--on-primary);
  padding: var(--spacing-xxl);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.card-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.6;
  mix-blend-mode: overlay;
  transition: transform 0.7s;
}

.species-card:active .card-bg-image {
  transform: scale(1.1);
}

.card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, transparent 0%, rgba(74, 93, 78, 0.8) 100%);
}

.card-content {
  position: relative;
  z-index: 10;
}

.card-title {
  display: block;
  font-family: var(--font-headline);
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
}

.card-desc {
  display: block;
  font-family: var(--font-body);
  font-size: 24rpx;
  color: var(--on-primary);
  opacity: 0.8;
  line-height: 1.6;
  max-width: 400rpx;
}

.card-icon {
  position: absolute;
  top: var(--spacing-lg);
  right: var(--spacing-lg);
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: var(--blur-glass);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon {
  font-size: 40rpx;
}

/* Certificate Card (Medium with Gold) */
.certificate-card {
  height: 336rpx;
  background: var(--surface-container-lowest);
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  border: 1rpx solid rgba(110, 94, 0, 0.1);
  transition: all 0.4s;
}

.certificate-card:active {
  box-shadow: 0 16rpx 48rpx rgba(110, 94, 0, 0.1);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.card-icon-gold {
  font-size: 48rpx;
}

.new-badge {
  background: var(--secondary-container);
  color: var(--on-secondary-container);
  font-family: var(--font-label);
  font-size: 18rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
  letter-spacing: 1rpx;
}

.card-bottom {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.card-title-sm {
  font-family: var(--font-headline);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--on-surface);
}

.card-subtitle {
  font-family: var(--font-label);
  font-size: 20rpx;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* Calendar Card (Medium) */
.calendar-card {
  height: 336rpx;
  background: var(--surface-container-high);
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  transition: all 0.4s;
}

.calendar-card:active {
  background: var(--surface-container-highest);
}

.card-icon-outline {
  font-size: 48rpx;
  opacity: 0.6;
}

.calendar-indicator {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.indicator-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--error);
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.indicator-text {
  font-family: var(--font-label);
  font-size: 20rpx;
  color: var(--on-surface-variant);
  font-weight: 500;
}

/* Ranking Card (Medium) */
.ranking-card {
  height: 224rpx;
  background: var(--surface-container);
  padding: var(--spacing-lg);
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: transform 0.4s;
}

.ranking-card:active {
  transform: scale(0.99);
}

.ranking-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.ranking-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.ranking-icon {
  width: 80rpx;
  height: 80rpx;
  background: var(--primary-container);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.ranking-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ranking-count {
  font-family: var(--font-body);
  font-size: 22rpx;
  color: var(--on-surface-variant);
}

.ranking-avatars {
  display: flex;
  gap: 8rpx;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid var(--surface);
}

.avatar-more {
  width: 56rpx;
  height: 56rpx;
  background: var(--surface-container-highest);
  border-radius: 50%;
  border: 4rpx solid var(--surface);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-label);
  font-size: 18rpx;
  font-weight: 600;
  color: var(--primary);
}

/* ===== News Banner ===== */
.news-banner {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--surface-container-low);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.news-label {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-family: var(--font-headline);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary);
  padding-right: var(--spacing-md);
  border-right: 1rpx solid var(--outline-variant);
  flex-shrink: 0;
}

.news-icon {
  font-size: 28rpx;
}

.news-content {
  flex: 1;
  overflow: hidden;
}

.news-text {
  font-family: var(--font-body);
  font-size: 24rpx;
  color: var(--on-surface-variant);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.news-arrow {
  font-size: 40rpx;
  color: var(--primary);
  opacity: 0.4;
  flex-shrink: 0;
}

/* ===== Navigation Icons ===== */
.action-icon {
  font-size: 40rpx;
  color: var(--secondary-fixed);
  opacity: 0.8;
  margin-left: var(--spacing-md);
  transition: opacity 0.3s;
}

.action-icon:active {
  opacity: 1;
}
