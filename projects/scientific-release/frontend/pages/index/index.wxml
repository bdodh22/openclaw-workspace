<!--pages/index/index.wxml - Modern Zen Design-->
<view class="container">
  <!-- 沉浸式首屏 - 动态背景 -->
  <view class="banner">
    <view class="banner-content animate-fade-in">
      <text class="banner-title">科学放生</text>
      <text class="banner-subtitle">如法祈福 · 保护生态</text>
      
      <!-- 禅语打字机效果 -->
      <view class="zen-quote">
        <text class="zen-text">{{dailyWisdom}}</text>
      </view>
      
      <!-- 核心按钮 - 立即放生 -->
      <button class="btn-release" bindtap="goToSpecies">立即放生</button>
    </view>
  </view>

  <!-- Bento Grid 功能布局 -->
  <view class="bento-grid">
    <!-- 大卡片 - 功德榜 -->
    <view class="bento-card large gold animate-fade-in animate-delay-1" bindtap="goToRanking">
      <view class="bento-icon">🏆</view>
      <view class="bento-title">功德榜</view>
      <view class="bento-subtitle">查看排名 · 积累福报</view>
    </view>
    
    <!-- 物种查询 -->
    <view class="bento-card animate-fade-in animate-delay-2" bindtap="goToSpecies">
      <view class="bento-icon">🐟</view>
      <view class="bento-title">物种查询</view>
      <view class="bento-subtitle">如法选择</view>
    </view>
    
    <!-- 生成祈福 -->
    <view class="bento-card animate-fade-in animate-delay-3" bindtap="goToCertificate">
      <view class="bento-icon">📿</view>
      <view class="bento-title">生成祈福</view>
      <view class="bento-subtitle">电子证书</view>
    </view>
    
    <!-- 斋日查询 -->
    <view class="bento-card animate-fade-in animate-delay-4" bindtap="goToCalendar">
      <view class="bento-icon">📅</view>
      <view class="bento-title">斋日查询</view>
      <view class="bento-subtitle">吉祥日子</view>
    </view>
    
    <!-- 我的功德 -->
    <view class="bento-card animate-fade-in animate-delay-4" bindtap="goToProfile">
      <view class="bento-icon">🙏</view>
      <view class="bento-title">我的功德</view>
      <view class="bento-subtitle">个人记录</view>
    </view>
  </view>

  <!-- 每日智慧 - 禅意卡片 -->
  <view class="wisdom-section animate-fade-in">
    <view class="wisdom-content">
      <text class="wisdom-text">{{dailyWisdom}}</text>
      <text class="wisdom-source" wx:if="{{wisdomSource}}">—— {{wisdomSource}}</text>
    </view>
  </view>

  <!-- 重要提醒 - 简约风格 -->
  <view class="notice-section animate-fade-in">
    <view class="section-title">重要提醒</view>
    <view class="notice-list">
      <view class="notice-item">
        <view class="notice-icon">⚠️</view>
        <view>
          <text class="notice-text">请勿放生外来物种，违法可能面临罚款</text>
          <text class="notice-time">法律法规</text>
        </view>
      </view>
      <view class="notice-item">
        <view class="notice-icon">✅</view>
        <view>
          <text class="notice-text">选择本地物种，科学放生才能真正积福</text>
          <text class="notice-time">生态友好</text>
        </view>
      </view>
    </view>
  </view>
</view>
