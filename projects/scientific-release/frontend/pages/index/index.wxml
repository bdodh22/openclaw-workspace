<!--pages/index/index.wxml - Stitch Design: Bento Grid 布局-->
<view class="container">
  <!-- Top Navigation -->
  <view class="top-nav">
    <view class="nav-brand">
      <text class="brand-icon">🌿</text>
      <text class="brand-title">生灵守护</text>
    </view>
    <view class="nav-actions">
      <text class="action-icon">🔍</text>
      <text class="action-icon">🔔</text>
    </view>
  </view>

  <!-- Main Content -->
  <view class="main-content">
    <!-- Daily Wisdom Section -->
    <view class="wisdom-section">
      <view class="wisdom-card">
        <text class="wisdom-quote-icon">❝</text>
        <text class="wisdom-label">Daily Wisdom · 每日一禅</text>
        <text class="wisdom-text">「万物并育而不相害，道并行而不相悖。科学放生，是智者的慈悲。」</text>
        <view class="wisdom-footer">
          <text class="wisdom-date">{{currentDate}}</text>
          <view class="share-btn" bindtap="shareWisdom">
            <text>分享智慧</text>
            <text class="arrow-icon">→</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Bento Grid Layout -->
    <view class="bento-grid">
      <!-- Species Query (Large) -->
      <view class="bento-card bento-large species-card" bindtap="goToSpecies">
        <view class="card-bg-placeholder"></view>
        <view class="card-overlay"></view>
        <view class="card-content">
          <text class="card-title">物种查询</text>
          <text class="card-desc">科学辨识适放物种，守护生态平衡之美。</text>
        </view>
        <view class="card-icon">
          <text class="icon">🔬</text>
        </view>
      </view>

      <!-- Prayer Certificate (Medium with Gold) -->
      <view class="bento-card certificate-card" bindtap="goToCertificate">
        <view class="card-top">
          <text class="card-icon-gold">🏆</text>
          <view class="new-badge">NEW</view>
        </view>
        <view class="card-bottom">
          <text class="card-title-sm">功德证书</text>
          <text class="card-subtitle gold-foil-text">Honorary Award</text>
        </view>
      </view>

      <!-- Buddhist Calendar (Medium) -->
      <view class="bento-card calendar-card" bindtap="goToCalendar">
        <view class="card-top">
          <text class="card-icon-outline">📅</text>
        </view>
        <view class="card-bottom">
          <text class="card-title-sm">佛历吉日</text>
          <view class="calendar-indicator">
            <view class="indicator-dot"></view>
            <text class="indicator-text">今日宜：戒杀、放生</text>
          </view>
        </view>
      </view>

      <!-- Merit Ranking (Medium) -->
      <view class="bento-card bento-large ranking-card" bindtap="goToRanking">
        <view class="ranking-content">
          <view class="ranking-left">
            <view class="ranking-icon">📊</view>
            <view class="ranking-info">
              <text class="card-title-sm">功德榜单</text>
              <text class="ranking-count">已有 12,840 位同修参与科学放生</text>
            </view>
          </view>
          <view class="ranking-avatars">
            <view class="avatar avatar-1">👤</view>
            <view class="avatar avatar-2">👤</view>
            <view class="avatar avatar-3">👤</view>
            <view class="avatar-more">+99</view>
          </view>
        </view>
      </view>
    </view>

    <!-- News Banner -->
    <view class="news-banner">
      <view class="news-label">
        <text class="news-icon">📢</text>
        <text>公告</text>
      </view>
      <view class="news-content">
        <text class="news-text">关于规范春季科学放生行为的指导意见...</text>
      </view>
      <text class="news-arrow">›</text>
    </view>
  </view>

  <!-- Bottom Navigation -->
  <view class="bottom-nav">
    <view class="nav-item active" bindtap="goToIndex">
      <text class="nav-icon">🏠</text>
      <text class="nav-label">首页</text>
    </view>
    <view class="nav-item" bindtap="goToSpecies">
      <text class="nav-icon">🐟</text>
      <text class="nav-label">物种</text>
    </view>
    <view class="nav-item" bindtap="goToCertificate">
      <text class="nav-icon">🏆</text>
      <text class="nav-label">证书</text>
    </view>
    <view class="nav-item" bindtap="goToProfile">
      <text class="nav-icon">👤</text>
      <text class="nav-label">我的</text>
    </view>
  </view>
</view>
