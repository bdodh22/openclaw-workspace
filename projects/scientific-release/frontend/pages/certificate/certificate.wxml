<!--pages/certificate/certificate.wxml - Stitch Design: 烫金证书-->
<view class="container">
  <!-- Top Navigation -->
  <view class="top-nav">
    <view class="nav-brand">
      <text class="brand-icon">🌿</text>
      <text class="brand-title">生灵守护</text>
    </view>
    <view class="nav-actions">
      <text class="action-icon" bindtap="closeCertificate">✕</text>
    </view>
  </view>

  <!-- Main Canvas -->
  <view class="certificate-canvas">
    <!-- Decoration: Lotus Petals -->
    <view class="decoration-lotus">🪷</view>
    <view class="decoration-water">💧</view>

    <!-- Certificate Card -->
    <view class="certificate-card">
      <!-- Gold Border -->
      <view class="gold-border-wrapper">
        <view class="certificate-body">
          <!-- Watermark -->
          <view class="watermark">🌊</view>

          <!-- Header -->
          <view class="certificate-header">
            <text class="certificate-title gold-foil-text">放生祈福证书</text>
            <view class="title-divider"></view>
          </view>

          <!-- Content Body -->
          <view class="certificate-content">
            <view class="content-row">
              <text class="user-name gold-foil-text">{{userName}}</text>
              <text>大德：</text>
            </view>

            <view class="content-row indent">
              <text>欣逢吉祥之日，阁下于</text>
              <text class="highlight">{{releaseDate}}</text>
              <text>在</text>
              <text class="highlight">{{releaseLocation}}</text>
              <text>科学放生</text>
              <text class="highlight">{{speciesName}}</text>
              <text>壹只。</text>
            </view>

            <view class="content-row center italic">
              <text>"愿诸众生，永离众苦，常受安乐。"</text>
            </view>
          </view>

          <!-- Bottom Metadata -->
          <view class="certificate-footer">
            <view class="footer-item">
              <text class="footer-label">功德编号</text>
              <text class="footer-value gold-foil-text">{{certificateNo}}</text>
            </view>
            <view class="footer-item">
              <text class="footer-label">福报值</text>
              <text class="footer-value gold-foil-text">+{{meritPoints}} BP</text>
            </view>
          </view>

          <!-- Red Stamp -->
          <view class="red-stamp">
            <text class="stamp-text">科学放生<br/>功德委员会<br/>印</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Action Buttons -->
    <view class="action-buttons">
      <button class="action-btn secondary" bindtap="saveToAlbum">
        <text class="btn-icon">⬇</text>
        <text>保存到相册</text>
      </button>
      <button class="action-btn primary" bindtap="shareToFriends">
        <text class="btn-icon">↗</text>
        <text>转发给好友</text>
      </button>
    </view>

    <!-- Footer Quote -->
    <text class="footer-quote">每一个细微的善举，都在改变世界的呼吸</text>
  </view>

  <!-- Bottom Navigation -->
  <view class="bottom-nav">
    <view class="nav-item" bindtap="goToIndex">
      <text class="nav-icon">🏠</text>
      <text class="nav-label">首页</text>
    </view>
    <view class="nav-item" bindtap="goToSpecies">
      <text class="nav-icon">🐟</text>
      <text class="nav-label">物种</text>
    </view>
    <view class="nav-item active">
      <text class="nav-icon">🏆</text>
      <text class="nav-label">证书</text>
    </view>
    <view class="nav-item" bindtap="goToProfile">
      <text class="nav-icon">👤</text>
      <text class="nav-label">我的</text>
    </view>
  </view>
</view>
