/* pages/certificate/certificate.wxss - Modern Zen Design: 动态电子证书 + 烫金效果 */

/* ===== 容器 - 宣纸质感背景 ===== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  padding: 32rpx;
  padding-bottom: 48rpx;
}

/* ===== 卡片系统 ===== */
.card {
  background: var(--bg-card);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10rpx);
}

/* ===== 物种信息 - 悬浮卡片 ===== */
.species-info {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 36rpx;
  background: linear-gradient(135deg, rgba(74, 93, 78, 0.05) 0%, rgba(74, 93, 78, 0.1) 100%);
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(74, 93, 78, 0.15);
  position: relative;
  overflow: hidden;
}

.species-info::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(201, 169, 97, 0.08) 0%, transparent 70%);
  animation: shimmer 8s linear infinite;
}

@keyframes shimmer {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.species-icon {
  font-size: 96rpx;
  filter: drop-shadow(0 4rpx 16rpx rgba(74, 93, 78, 0.2));
  position: relative;
  z-index: 10;
}

.species-detail {
  flex: 1;
  position: relative;
  z-index: 10;
}

.species-name {
  font-size: 42rpx;
  font-weight: 300;
  color: var(--primary-color);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.species-scientific {
  font-size: 26rpx;
  color: var(--text-hint);
  font-style: italic;
  font-family: Georgia, 'Times New Roman', serif;
  letter-spacing: 1rpx;
}

/* ===== 表单组 - 新中式 ===== */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 400;
  margin-bottom: 16rpx;
  display: block;
  letter-spacing: 1rpx;
  padding-left: 12rpx;
  border-left: 3rpx solid var(--accent-gold);
}

.form-input {
  width: 100%;
  padding: 28rpx 32rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
  box-sizing: border-box;
  transition: all 0.3s;
}

.form-input:focus {
  border-color: var(--accent-gold);
  box-shadow: 0 0 0 4rpx rgba(201, 169, 97, 0.1);
}

.form-input::placeholder {
  color: var(--text-hint);
}

.form-textarea {
  width: 100%;
  padding: 28rpx 32rpx;
  background: var(--bg-card);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  border: 1rpx solid var(--border-color);
  box-sizing: border-box;
  min-height: 240rpx;
  line-height: 1.8;
  resize: none;
  transition: all 0.3s;
}

.form-textarea:focus {
  border-color: var(--accent-gold);
  box-shadow: 0 0 0 4rpx rgba(201, 169, 97, 0.1);
}

/* ===== 善愿提示 - 禅意卡片 ===== */
.tips {
  background: linear-gradient(135deg, rgba(201, 169, 97, 0.05) 0%, rgba(201, 169, 97, 0.08) 100%);
  border-left: 4rpx solid var(--accent-gold);
  padding: 28rpx 32rpx;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
}

.tips-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 2;
  font-style: italic;
}

/* ===== 提交按钮 - 烫金效果 ===== */
.submit-btn {
  background: linear-gradient(135deg, var(--accent-gold) 0%, #B8945E 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 400;
  width: 100%;
  margin-top: 32rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(201, 169, 97, 0.4);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.submit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.6s;
}

.submit-btn:active::before {
  left: 100%;
}

.submit-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 16rpx rgba(201, 169, 97, 0.3);
}

.submit-btn:disabled {
  opacity: 0.5;
  transform: none;
}

/* ===== 祈福预览 - 动态电子证书 ===== */
.blessing-preview {
  position: relative;
  background: linear-gradient(135deg, rgba(201, 169, 97, 0.08) 0%, rgba(201, 169, 97, 0.12) 100%);
  padding: 48rpx 40rpx;
  border-radius: 28rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid rgba(201, 169, 97, 0.3);
  overflow: hidden;
}

/* 动态背景 - 飘落樱花/游动鱼群 */
.blessing-preview::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 20% 30%, rgba(255, 183, 197, 0.1) 0%, transparent 20%),
    radial-gradient(circle at 80% 70%, rgba(201, 169, 97, 0.1) 0%, transparent 20%);
  animation: float 15s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20rpx) scale(1.05); }
}

.blessing-label {
  position: relative;
  z-index: 10;
  font-size: 28rpx;
  color: var(--accent-gold);
  margin-bottom: 20rpx;
  text-align: center;
  letter-spacing: 3rpx;
  font-weight: 400;
}

.blessing-content {
  position: relative;
  z-index: 10;
  font-size: 32rpx;
  color: var(--text-primary);
  line-height: 2.2;
  text-align: center;
  font-style: italic;
  letter-spacing: 2rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

/* 烫金文字效果 */
.text-gold-emboss {
  background: linear-gradient(135deg, var(--accent-gold) 0%, #E5C55A 50%, var(--accent-gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  background-size: 200% auto;
  animation: goldShimmer 3s linear infinite;
}

@keyframes goldShimmer {
  0% { background-position: 0% center; }
  100% { background-position: 200% center; }
}

/* ===== 功德编号 - 烫金徽章 ===== */
.merit-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx 40rpx;
  background: linear-gradient(135deg, rgba(201, 169, 97, 0.1) 0%, rgba(201, 169, 97, 0.15) 100%);
  border-radius: 48rpx;
  border: 2rpx solid rgba(201, 169, 97, 0.3);
  margin-bottom: 32rpx;
}

.merit-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.merit-number {
  font-size: 36rpx;
  font-weight: 400;
  color: var(--accent-gold);
  letter-spacing: 2rpx;
  font-family: 'Courier New', monospace;
}

/* ===== 生成成功 - 仪式感动效 ===== */
.success-animation {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  animation: successPop 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
}

@keyframes successPop {
  0% { transform: scale(0) rotate(-180deg); opacity: 0; }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.success-title {
  font-size: 40rpx;
  font-weight: 300;
  color: var(--primary-color);
  margin-bottom: 16rpx;
  letter-spacing: 3rpx;
}

.success-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.8;
}

/* ===== 分享按钮组 ===== */
.share-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.share-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.3s;
}

.share-btn-primary {
  background: linear-gradient(135deg, var(--accent-gold) 0%, #B8945E 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(201, 169, 97, 0.4);
}

.share-btn-secondary {
  background: var(--bg-card);
  color: var(--primary-color);
  border: 1rpx solid var(--primary-color);
}

.share-btn:active {
  transform: scale(0.96);
}

/* ===== 证书预览 - 数字藏品风格 ===== */
.certificate-preview {
  position: relative;
  background: linear-gradient(135deg, #FDFBF7 0%, #F9F8F4 100%);
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 32rpx;
  border: 3rpx solid rgba(201, 169, 97, 0.2);
  box-shadow: 0 12rpx 48rpx rgba(74, 93, 78, 0.12);
  overflow: hidden;
}

/* 证书边框装饰 */
.certificate-preview::before {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  border: 2rpx solid rgba(201, 169, 97, 0.3);
  border-radius: 24rpx;
  pointer-events: none;
}

/* 四角装饰 */
.certificate-preview::after {
  content: '❖';
  position: absolute;
  font-size: 40rpx;
  color: var(--accent-gold);
  opacity: 0.3;
}

.cert-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.cert-title {
  font-size: 48rpx;
  font-weight: 300;
  color: var(--primary-color);
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
}

.cert-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}

.cert-body {
  text-align: center;
  margin-bottom: 48rpx;
}

.cert-text {
  font-size: 32rpx;
  color: var(--text-primary);
  line-height: 2.4;
  letter-spacing: 2rpx;
}

.cert-name {
  font-size: 40rpx;
  font-weight: 400;
  color: var(--accent-gold);
  margin: 24rpx 0;
  padding: 20rpx 40rpx;
  background: rgba(201, 169, 97, 0.1);
  border-radius: 16rpx;
  display: inline-block;
}

.cert-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 32rpx;
  border-top: 1rpx solid var(--border-color);
}

.cert-date {
  font-size: 26rpx;
  color: var(--text-hint);
}

.cert-seal {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201, 169, 97, 0.2) 0%, rgba(201, 169, 97, 0.05) 100%);
  border: 3rpx solid var(--accent-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--accent-gold);
  box-shadow: 0 4rpx 16rpx rgba(201, 169, 97, 0.3);
}

/* ===== 动画效果 ===== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in {
  animation: fadeInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.animate-delay-1 { animation-delay: 0.1s; }
.animate-delay-2 { animation-delay: 0.2s; }
.animate-delay-3 { animation-delay: 0.3s; }

/* 飘落花瓣动画 */
@keyframes petalFall {
  0% {
    transform: translateY(-100rpx) rotate(0deg);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  100% {
    transform: translateY(600rpx) rotate(360deg);
    opacity: 0;
  }
}

.petal {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  background: radial-gradient(circle, rgba(255, 183, 197, 0.6) 0%, transparent 70%);
  border-radius: 50% 0 50% 0;
  animation: petalFall 8s linear infinite;
  pointer-events: none;
}

.petal:nth-child(1) { left: 10%; animation-delay: 0s; }
.petal:nth-child(2) { left: 30%; animation-delay: 2s; }
.petal:nth-child(3) { left: 50%; animation-delay: 4s; }
.petal:nth-child(4) { left: 70%; animation-delay: 6s; }
.petal:nth-child(5) { left: 90%; animation-delay: 1s; }
