/* pages/certificate/certificate.wxss - Stitch Design: 烫金证书 */

.container {
  min-height: 100vh;
  background: var(--surface);
  padding-bottom: 160rpx;
}

.certificate-canvas {
  padding: var(--spacing-xxl) var(--spacing-lg);
  padding-top: 140rpx;
  position: relative;
  overflow: hidden;
}

/* Decorations */
.decoration-lotus {
  position: absolute;
  top: 160rpx;
  right: -40rpx;
  font-size: 160rpx;
  opacity: 0.1;
  transform: rotate(12deg);
  pointer-events: none;
}

.decoration-water {
  position: absolute;
  bottom: 280rpx;
  left: -60rpx;
  font-size: 180rpx;
  opacity: 0.1;
  transform: rotate(-12deg);
  pointer-events: none;
}

/* Certificate Card */
.certificate-card {
  max-width: 600rpx;
  margin: 0 auto var(--spacing-xl);
  transition: all 0.4s ease-in-out;
}

.gold-border-wrapper {
  position: relative;
  background: var(--primary-container);
  padding: 12rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.certificate-body {
  position: relative;
  background: var(--primary-container);
  padding: var(--spacing-xxl);
  border: 12rpx double rgba(254, 226, 100, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Watermark */
.watermark {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 400rpx;
  opacity: 0.05;
  pointer-events: none;
  z-index: 0;
}

/* Header */
.certificate-header {
  text-align: center;
  margin-bottom: var(--spacing-xxl);
  z-index: 10;
}

.certificate-title {
  font-family: var(--font-headline);
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  padding: var(--spacing-sm) 0;
}

.title-divider {
  width: 200rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, var(--secondary-fixed) 50%, transparent 100%);
  margin: var(--spacing-sm) auto 0;
}

/* Content */
.certificate-content {
  width: 100%;
  z-index: 10;
}

.content-row {
  font-family: var(--font-headline);
  font-size: 32rpx;
  line-height: 2;
  color: var(--on-primary-container);
  margin-bottom: var(--spacing-md);
}

.content-row.indent {
  text-indent: 64rpx;
}

.content-row.center {
  text-align: center;
  font-style: italic;
  color: var(--secondary-fixed-dim);
  font-size: 36rpx;
  margin-top: var(--spacing-xl);
}

.content-row .highlight {
  color: var(--secondary-fixed);
  font-weight: 600;
  border-bottom: 2rpx solid rgba(254, 226, 100, 0.3);
  padding-bottom: 4rpx;
}

.content-row .user-name {
  font-size: 40rpx;
  font-weight: 700;
}

/* Footer */
.certificate-footer {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-lg);
  margin-top: var(--spacing-xxl);
  padding-top: var(--spacing-lg);
  border-top: 2rpx solid rgba(255, 255, 255, 0.1);
  z-index: 10;
}

.footer-item {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.footer-label {
  font-family: var(--font-label);
  font-size: 18rpx;
  color: var(--on-primary-container);
  opacity: 0.6;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.footer-value {
  font-family: var(--font-body);
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* Red Stamp */
.red-stamp {
  position: absolute;
  bottom: var(--spacing-xl);
  right: var(--spacing-xl);
  width: 128rpx;
  height: 128rpx;
  border: 8rpx solid rgba(186, 26, 26, 0.7);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm);
  opacity: 0.8;
  mix-blend-mode: screen;
  transform: rotate(-12deg);
  z-index: 20;
}

.stamp-text {
  font-family: var(--font-headline);
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(186, 26, 26, 0.9);
  text-align: center;
  line-height: 1.4;
}

/* Action Buttons */
.action-buttons {
  max-width: 600rpx;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-md);
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-lg) var(--spacing-xl);
  border-radius: var(--radius-lg);
  font-family: var(--font-label);
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.4s;
}

.action-btn.secondary {
  background: var(--surface-container-highest);
  color: var(--on-surface);
}

.action-btn.secondary:active {
  background: var(--surface-container-high);
}

.action-btn.primary {
  background: var(--primary-container);
  color: var(--on-primary-container);
  box-shadow: 0 8rpx 24rpx rgba(74, 93, 78, 0.3);
}

.action-btn.primary:active {
  opacity: 0.9;
}

.btn-icon {
  font-size: 32rpx;
}

/* Footer Quote */
.footer-quote {
  display: block;
  text-align: center;
  font-family: var(--font-label);
  font-size: 20rpx;
  color: var(--on-surface-variant);
  opacity: 0.6;
  letter-spacing: 4rpx;
  margin-top: var(--spacing-xxl);
  padding-bottom: var(--spacing-lg);
}

/* Action Icons */
.action-icon {
  font-size: 40rpx;
  color: var(--secondary-fixed);
  opacity: 0.8;
  transition: opacity 0.3s;
}

.action-icon:active {
  opacity: 1;
}
