/* pages/achievements/achievements.wxss - 成就系统页面样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  padding: 32rpx;
  padding-bottom: 48rpx;
}

/* 页面标题 */
.page-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  font-weight: 300;
  color: var(--primary-color);
  letter-spacing: 3rpx;
  margin-bottom: 8rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  letter-spacing: 1rpx;
}

/* 进度总览卡片 */
.overview-card {
  background: var(--bg-card);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 400;
}

.overview-level {
  font-size: 28rpx;
  color: #C9B037;
  background: linear-gradient(135deg, rgba(201, 176, 55, 0.1) 0%, rgba(201, 176, 55, 0.2) 100%);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(201, 176, 55, 0.3);
}

.progress-bar {
  height: 16rpx;
  background: rgba(74, 93, 78, 0.1);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #C9B037 0%, #E5C55A 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease-out;
  box-shadow: 0 2rpx 8rpx rgba(201, 176, 55, 0.4);
}

.progress-text {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 分类标签 */
.category-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  overflow-x: auto;
  padding: 8rpx 4rpx;
}

.tab-item {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  background: var(--bg-card);
  border-radius: 32rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #4A5D4E 0%, #3A4A3E 100%);
  color: #FFFFFF;
  border-color: #4A5D4E;
  box-shadow: 0 4rpx 16rpx rgba(74, 93, 78, 0.3);
}

/* 成就卡片 */
.achievements-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.achievement-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid var(--border-color);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.achievement-card.unlocked {
  border-color: rgba(201, 176, 55, 0.4);
  box-shadow: 0 4rpx 20rpx rgba(201, 176, 55, 0.15);
}

.achievement-card.locked {
  opacity: 0.7;
  filter: grayscale(0.5);
}

/* 成就图标 */
.achievement-icon {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(201, 176, 55, 0.1) 0%, rgba(201, 176, 55, 0.2) 100%);
  border-radius: 50%;
  border: 2rpx solid rgba(201, 176, 55, 0.3);
}

.achievement-icon .icon {
  font-size: 56rpx;
  position: relative;
  z-index: 10;
}

.unlock-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(201, 176, 55, 0.3) 0%, transparent 70%);
  animation: glow-pulse 2s ease-in-out infinite;
}

@keyframes glow-pulse {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.1); }
}

/* 成就信息 */
.achievement-info {
  flex: 1;
  min-width: 0;
}

.achievement-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.achievement-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 400;
}

.achievement-badge {
  background: linear-gradient(135deg, #C9B037 0%, #E5C55A 100%);
  color: #FFFFFF;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.achievement-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 12rpx;
}

/* 成就进度 */
.achievement-progress {
  margin-top: 12rpx;
}

.progress-bar-small {
  height: 8rpx;
  background: rgba(74, 93, 78, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill-small {
  height: 100%;
  background: linear-gradient(90deg, #4A5D4E 0%, #5A6D5E 100%);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text-small {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 成就奖励 */
.achievement-reward {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.reward-icon {
  font-size: 32rpx;
}

.reward-text {
  font-size: 24rpx;
  color: #C9B037;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: var(--text-secondary);
}
