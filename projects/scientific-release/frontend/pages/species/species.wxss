/* pages/species/species.wxss - Stitch Design: 生命图鉴式卡片 */

/* ===== Design Tokens ===== */
page {
  /* Colors from DESIGN.md */
  --primary: #334537;
  --primary-container: #4A5D4E;
  --on-primary: #FFFFFF;
  --on-primary-fixed: #0E1F13;
  --primary-fixed: #D3E8D5;
  --primary-fixed-dim: #B7CCB9;
  
  --secondary: #6E5E00;
  --secondary-container: #FEE264;
  --on-secondary: #FFFFFF;
  --on-secondary-fixed: #211B00;
  --secondary-fixed: #FEE264;
  --secondary-fixed-dim: #E0C64B;
  
  --surface: #FAF9F4;
  --surface-container: #EFEEE9;
  --surface-container-low: #F5F4EF;
  --surface-container-lowest: #FFFFFF;
  --surface-container-high: #E9E8E3;
  --surface-container-highest: #E3E2DE;
  
  --on-surface: #1B1C19;
  --on-surface-variant: #434843;
  
  --outline: #737872;
  --outline-variant: #C3C8C1;
  
  --error: #BA1A1A;
  --error-container: #FFDAD6;
  --on-error: #FFFFFF;
  
  /* Typography */
  --font-headline: 'Noto Serif', serif;
  --font-body: 'Plus Jakarta Sans', sans-serif;
  --font-label: 'Plus Jakarta Sans', sans-serif;
  
  /* Spacing */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 40rpx;
  
  /* Border Radius */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
  
  /* Shadows */
  --shadow-ambient: 0 4rpx 20rpx rgba(27, 28, 25, 0.04);
  --shadow-elevated: 0 8rpx 32rpx rgba(27, 28, 25, 0.08);
  --shadow-floated: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
}

/* ===== Container ===== */
.container {
  min-height: 100vh;
  background: var(--surface);
  padding-bottom: 120rpx;
}

/* ===== Top Navigation Bar ===== */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 112rpx;
  padding: 0 var(--spacing-lg);
  background: var(--primary-container);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.nav-brand {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.brand-icon {
  font-size: 48rpx;
}

.brand-title {
  font-family: var(--font-headline);
  font-size: 36rpx;
  font-weight: 600;
  color: var(--secondary-fixed);
  letter-spacing: 4rpx;
}

.nav-links {
  display: flex;
  gap: var(--spacing-lg);
}

.nav-link {
  font-family: var(--font-label);
  font-size: 20rpx;
  color: var(--secondary-fixed);
  opacity: 0.7;
  transition: opacity 0.3s;
}

.nav-link.active {
  opacity: 1;
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 16rpx;
  text-decoration-color: var(--secondary-fixed);
}

/* ===== Search Section ===== */
.search-section {
  margin-top: 140rpx;
  margin-bottom: var(--spacing-md);
  padding: 0 var(--spacing-lg);
}

.search-bar {
  position: relative;
  display: flex;
  align-items: center;
  background: var(--surface-container-highest);
  backdrop-filter: blur(20rpx);
  border-radius: var(--radius-full);
  padding: var(--spacing-sm) var(--spacing-lg);
  border: 1rpx solid var(--outline-variant);
  box-shadow: var(--shadow-ambient);
}

.search-icon {
  font-size: 40rpx;
  color: var(--on-surface-variant);
  margin-right: var(--spacing-sm);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--on-surface);
  background: transparent;
  border: none;
  padding: var(--spacing-sm) 0;
}

.search-input::placeholder {
  color: var(--on-surface-variant);
  opacity: 0.6;
}

.filter-btn {
  background: transparent;
  border: none;
  padding: var(--spacing-sm);
  margin-left: var(--spacing-xs);
}

.filter-icon {
  font-size: 40rpx;
  color: var(--primary);
}

/* ===== Category Section ===== */
.category-section {
  margin-bottom: var(--spacing-lg);
  padding: 0 var(--spacing-lg);
  overflow: hidden;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: var(--spacing-sm);
  padding: var(--spacing-xs) 0;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  padding: 20rpx 48rpx;
  background: var(--surface-container);
  border-radius: var(--radius-full);
  font-family: var(--font-label);
  font-size: 24rpx;
  font-weight: 500;
  color: var(--on-surface-variant);
  box-shadow: var(--shadow-ambient);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  white-space: nowrap;
}

.category-chip:active {
  transform: scale(0.96);
}

.category-chip.active {
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-fixed) 100%);
  color: var(--on-secondary-fixed);
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(110, 94, 0, 0.3);
}

/* ===== Species Grid ===== */
.species-grid {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
  padding: 0 var(--spacing-lg);
}

/* ===== Species Card ===== */
.species-card {
  background: var(--surface-container-lowest);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xl);
  box-shadow: var(--shadow-ambient);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  gap: var(--spacing-lg);
  align-items: flex-start;
}

.species-card:active {
  transform: translateY(-8rpx);
  box-shadow: var(--shadow-elevated);
}

/* Species Image - Circular Cutout */
.species-image-wrapper {
  position: relative;
  flex-shrink: 0;
}

.species-image {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 8rpx solid var(--surface-container-low);
  box-shadow: inset 0 8rpx 24rpx rgba(74, 93, 78, 0.1);
}

.species-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s;
}

.species-card:active .species-img {
  transform: scale(1.1);
}

/* Prohibited Badge */
.prohibited-badge {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  background: var(--error);
  border-radius: 50%;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--surface-container-lowest);
  box-shadow: var(--shadow-ambient);
}

.badge-icon {
  font-size: 28rpx;
}

/* Card Content */
.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

/* Tags */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-sm);
  font-family: var(--font-label);
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.tag-native {
  background: var(--primary-fixed);
  color: var(--on-primary-fixed-variant);
}

.tag-prohibited {
  background: var(--error-container);
  color: var(--error);
}

.tag-classification {
  background: var(--primary-container);
  color: var(--on-primary);
}

/* Card Header */
.card-header {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.species-name-cn {
  font-family: var(--font-headline);
  font-size: 40rpx;
  font-weight: 500;
  color: var(--on-surface);
  line-height: 1.3;
}

.species-name-en {
  font-family: var(--font-body);
  font-size: 24rpx;
  font-style: italic;
  color: var(--on-surface-variant);
  opacity: 0.7;
}

/* Species Description */
.species-description {
  font-family: var(--font-body);
  font-size: 26rpx;
  color: var(--on-surface-variant);
  line-height: 1.8;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx var(--spacing-lg);
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: var(--spacing-lg);
  opacity: 0.3;
}

.empty-text {
  font-family: var(--font-headline);
  font-size: 36rpx;
  color: var(--on-surface-variant);
  font-weight: 500;
}

.empty-subtext {
  margin-top: var(--spacing-sm);
  font-size: 28rpx;
  color: var(--on-surface-variant);
  opacity: 0.7;
}

/* ===== Loading State ===== */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
}

.dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--primary-container);
  animation: breathe 1.5s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes breathe {
  0%, 100% { opacity: 0.3; transform: scale(0.9); }
  50% { opacity: 1; transform: scale(1.1); }
}

/* ===== Information Prompt ===== */
.info-prompt {
  margin: var(--spacing-xl) var(--spacing-lg);
  padding: var(--spacing-xl);
  background: var(--surface-container);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  box-shadow: var(--shadow-ambient);
}

.prompt-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--primary-container);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.prompt-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.prompt-title {
  font-family: var(--font-headline);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
}

.prompt-text {
  font-family: var(--font-body);
  font-size: 24rpx;
  color: var(--on-surface-variant);
  line-height: 1.6;
}

.learn-more-btn {
  background: transparent;
  border: none;
  padding: var(--spacing-sm);
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-family: var(--font-label);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary);
  white-space: nowrap;
}

.arrow-icon {
  font-size: 32rpx;
  transition: transform 0.3s;
}

.learn-more-btn:active .arrow-icon {
  transform: translateX(8rpx);
}

/* ===== Bottom Navigation Bar ===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 140rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--surface);
  backdrop-filter: blur(40rpx);
  border-radius: 48rpx 48rpx 0 0;
  box-shadow: var(--shadow-floated);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) var(--spacing-md);
  color: var(--on-surface-variant);
  opacity: 0.6;
  transition: all 0.4s;
}

.nav-item:active {
  transform: scale(0.95);
}

.nav-item.active {
  opacity: 1;
  background: var(--surface-container);
  border-radius: var(--radius-md);
}

.nav-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.nav-item.active .nav-icon {
  font-variation-settings: 'FILL' 1;
}

.nav-label {
  font-family: var(--font-label);
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.2;
}

/* ===== Responsive Adjustments ===== */
@media (max-width: 768px) {
  .nav-links {
    display: none;
  }
  
  .species-card {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  
  .card-tags {
    justify-content: center;
  }
  
  .card-header {
    align-items: center;
  }
}
