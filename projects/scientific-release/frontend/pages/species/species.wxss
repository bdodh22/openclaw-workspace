/* pages/species/species.wxss */

.search-bar {
  background: transparent;
  box-shadow: none;
  padding: 0;
  margin-bottom: 24rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: white;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 48rpx;
}

.search-btn {
  background: #4CAF50;
  color: white;
  border: none;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 48rpx;
}

.category-filter {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  overflow-x: auto;
  padding: 8rpx 0;
}

.category-item {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  background: white;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.category-item.active {
  background: #4CAF50;
  color: white;
}

.species-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.species-card {
  padding: 32rpx;
  transition: transform 0.2s;
}

.species-card:active {
  transform: scale(0.98);
}

.species-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.species-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.species-scientific {
  font-size: 24rpx;
  color: #999;
  font-style: italic;
}

.species-card-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.species-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
}

.tag-native {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-warning {
  background: #ffebee;
  color: #c62828;
}

.tag-category {
  background: #e3f2fd;
  color: #1976d2;
}

.species-habitat {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading,
.load-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}
