/* pages/species/species.wxss - Modern Zen Design: 生命图鉴式卡片 */

/* ===== 搜索栏 - 悬浮胶囊 ===== */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: linear-gradient(180deg, var(--bg-primary) 0%, rgba(249, 248, 244, 0.95) 100%);
  backdrop-filter: blur(20rpx);
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(74, 93, 78, 0.06);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--bg-card);
  padding: 8rpx;
  border-radius: 48rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-soft);
  transition: all 0.3s;
}

.search-input-wrap:focus-within {
  border-color: var(--primary-color);
  box-shadow: var(--shadow-elevated);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  padding: 18rpx 28rpx;
  background: transparent;
  border-radius: 40rpx;
  color: var(--text-primary);
}

.search-input::placeholder {
  color: var(--text-hint);
}

.search-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #FFFFFF;
  border: none;
  font-size: 28rpx;
  padding: 18rpx 36rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 93, 78, 0.25);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.search-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(74, 93, 78, 0.2);
}

/* ===== 分类筛选 - 胶囊标签 ===== */
.category-filter {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
  overflow-x: auto;
  padding: 8rpx 4rpx;
  -webkit-overflow-scrolling: touch;
}

.category-filter::-webkit-scrollbar {
  display: none;
}

.category-item {
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  background: var(--bg-card);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-soft);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  white-space: nowrap;
}

.category-item:active {
  transform: scale(0.96);
}

.category-item.active {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #FFFFFF;
  border-color: var(--primary-color);
  box-shadow: 0 4rpx 16rpx rgba(74, 93, 78, 0.3);
}

/* ===== 物种列表 - 生命图鉴式卡片 ===== */
.species-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 32rpx;
}

.species-card {
  background: var(--bg-card);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10rpx);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.species-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--accent-gold));
  opacity: 0;
  transition: opacity 0.3s;
}

.species-card:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-elevated);
}

.species-card:active::before {
  opacity: 1;
}

/* 本地物种 - 绿色边框 */
.species-card.native {
  border-left: 4rpx solid var(--primary-color);
}

/* 禁止放生 - 红色边框 */
.species-card.forbidden {
  border-left: 4rpx solid var(--error);
  background: linear-gradient(135deg, rgba(168, 107, 107, 0.03) 0%, rgba(168, 107, 107, 0.06) 100%);
}

.species-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 24rpx;
  gap: 20rpx;
}

.species-name {
  font-size: 40rpx;
  font-weight: 300;
  color: var(--text-primary);
  letter-spacing: 2rpx;
  line-height: 1.3;
}

.species-scientific {
  font-size: 24rpx;
  color: var(--text-hint);
  font-style: italic;
  font-family: Georgia, 'Times New Roman', serif;
  letter-spacing: 1rpx;
}

/* 物种插图区域 - 去底悬浮效果 */
.species-illustration {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(74, 93, 78, 0.05) 0%, rgba(74, 93, 78, 0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: inset 0 4rpx 16rpx rgba(74, 93, 78, 0.1);
  position: relative;
}

.species-illustration::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.8) 0%, transparent 70%);
  pointer-events: none;
}

.species-icon {
  font-size: 80rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(74, 93, 78, 0.2));
}

.species-card-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 标签系统 - 胶囊式 */
.species-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.tag-native {
  background: linear-gradient(135deg, rgba(74, 93, 78, 0.08) 0%, rgba(74, 93, 78, 0.12) 100%);
  color: var(--primary-color);
  border: 1rpx solid rgba(74, 93, 78, 0.2);
}

.tag-warning {
  background: linear-gradient(135deg, rgba(168, 107, 107, 0.08) 0%, rgba(168, 107, 107, 0.12) 100%);
  color: var(--error);
  border: 1rpx solid rgba(168, 107, 107, 0.2);
}

.tag-category {
  background: linear-gradient(135deg, rgba(201, 169, 97, 0.08) 0%, rgba(201, 169, 97, 0.12) 100%);
  color: var(--accent-gold);
  border: 1rpx solid rgba(201, 169, 97, 0.2);
}

/* 栖息地信息 */
.species-habitat {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 20rpx;
  background: var(--bg-secondary);
  border-radius: 16rpx;
  border-left: 3rpx solid var(--primary-color);
}

/* 放生意义 - 禅意卡片 */
.species-meaning {
  margin-top: 20rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(201, 169, 97, 0.05) 0%, rgba(201, 169, 97, 0.08) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(201, 169, 97, 0.15);
}

.meaning-title {
  font-size: 24rpx;
  color: var(--accent-gold);
  font-weight: 400;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.meaning-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  font-style: italic;
}

/* ===== 空状态 - 禅意留白 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
  filter: grayscale(100%);
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-hint);
  font-weight: 300;
  letter-spacing: 2rpx;
}

.empty-subtext {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-hint);
  opacity: 0.7;
}

/* ===== 加载状态 - 呼吸效果 ===== */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  gap: 12rpx;
}

.loading dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--primary-color);
  animation: breathe 1.5s ease-in-out infinite;
}

.loading dot:nth-child(2) { animation-delay: 0.2s; }
.loading dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes breathe {
  0%, 100% { opacity: 0.4; transform: scale(0.9); }
  50% { opacity: 1; transform: scale(1.1); }
}

/* ===== 加载更多 - 淡入式 ===== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
  font-weight: 300;
  letter-spacing: 2rpx;
  opacity: 0.6;
  transition: opacity 0.3s;
}

.load-more:active {
  opacity: 1;
}

/* ===== 容器 ===== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  padding-top: 24rpx;
  padding-bottom: 48rpx;
}

/* ===== 动画效果 ===== */
@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-slide-in {
  animation: slideInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.animate-delay-1 { animation-delay: 0.05s; }
.animate-delay-2 { animation-delay: 0.1s; }
.animate-delay-3 { animation-delay: 0.15s; }
.animate-delay-4 { animation-delay: 0.2s; }
.animate-delay-5 { animation-delay: 0.25s; }
