/* pages/species/species.wxss */

.search-bar {
  margin-bottom: 0;
  border-radius: 0;
  box-shadow: none;
  background: #FFFFFF;
  padding: 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.search-btn {
  height: 72rpx;
  line-height: 72rpx;
  background: #2E7D32;
  color: #FFFFFF;
  border: none;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.search-btn:active {
  background: #1B5E20;
}

.category-filter {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.category-item {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666666;
  transition: all 0.2s;
}

.category-item.active {
  background: #2E7D32;
  color: #FFFFFF;
}

.species-list {
  padding: 24rpx;
}

.species-card {
  margin-bottom: 24rpx;
  transition: transform 0.2s;
}

.species-card:active {
  transform: scale(0.98);
}

.species-card-header {
  margin-bottom: 16rpx;
}

.species-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.species-scientific {
  display: block;
  font-size: 24rpx;
  color: #999999;
  font-style: italic;
}

.species-card-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.species-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-native {
  background: #E8F5E9;
  color: #2E7D32;
}

.tag-warning {
  background: #FFEBEE;
  color: #C62828;
}

.tag-category {
  background: #E3F2FD;
  color: #1565C0;
}

.species-habitat {
  font-size: 26rpx;
  color: #666666;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.loading, .load-more {
  text-align: center;
  padding: 32rpx;
  color: #999999;
  font-size: 26rpx;
}
