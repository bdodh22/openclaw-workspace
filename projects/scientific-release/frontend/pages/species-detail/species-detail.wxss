/* pages/species-detail/species-detail.wxss */

.container {
  background: #F5F5F5;
  min-height: 100vh;
}

/* Species Header */
.species-header {
  position: relative;
  height: 400rpx;
  background-size: cover;
  background-position: center;
  background-color: #2E7D32;
  display: flex;
  align-items: flex-end;
  padding: 32rpx;
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.7) 100%);
}

.header-content {
  position: relative;
  z-index: 1;
}

.species-name {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.species-scientific {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-style: italic;
}

/* Status Banner */
.status-banner {
  margin: -40rpx 24rpx 24rpx;
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.status-banner.success {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.status-banner.warning {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
}

.status-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

/* Info Section */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #2E7D32;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* Precautions */
.precautions-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 24rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.tip-icon {
  color: #2E7D32;
  font-weight: bold;
  font-size: 28rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  flex: 1;
}

/* Warning Card */
.warning-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.warning-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
}

.warning-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #C62828;
  margin-bottom: 16rpx;
}

.warning-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.warning-subtext {
  display: block;
  font-size: 26rpx;
  color: #2E7D32;
  line-height: 1.6;
}

/* Action Bar */
.action-bar {
  padding: 32rpx;
  position: sticky;
  bottom: 0;
  background: #F5F5F5;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  color: #FFFFFF;
}

.action-btn.primary:active {
  opacity: 0.9;
}
