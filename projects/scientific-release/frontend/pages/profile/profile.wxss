/* pages/profile/profile.wxss - Stitch Design: 极简个人中心 */

.container {
  min-height: 100vh;
  background: var(--surface);
  padding-bottom: 160rpx;
}

.main-content {
  padding: var(--spacing-xxl) var(--spacing-lg);
  padding-top: 140rpx;
}

/* ===== Profile Header ===== */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: var(--spacing-xxl);
}

.avatar-wrapper {
  position: relative;
  margin-bottom: var(--spacing-md);
}

.avatar {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  padding: 8rpx;
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-fixed) 100%);
  box-shadow: 0 8rpx 24rpx rgba(110, 94, 0, 0.3);
}

.verified-badge {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: var(--secondary-container);
  color: var(--on-secondary-container);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  border: 4rpx solid var(--surface);
  box-shadow: var(--shadow-ambient);
}

.user-info {
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.user-name {
  font-family: var(--font-headline);
  font-size: 40rpx;
  font-weight: 600;
  color: var(--primary);
}

.user-level {
  display: inline-flex;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-xs) var(--spacing-md);
  background: var(--surface-container);
  border-radius: var(--radius-full);
}

.level-icon {
  font-size: 28rpx;
}

.level-text {
  font-family: var(--font-label);
  font-size: 20rpx;
  color: var(--on-surface-variant);
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* ===== Stats Grid ===== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-xxl);
}

.stat-card {
  background: var(--surface-container-lowest);
  padding: var(--spacing-lg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-ambient);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: var(--spacing-xs);
}

.stat-card.highlight {
  border-left: 8rpx solid var(--secondary);
}

.stat-value {
  font-family: var(--font-headline);
  font-size: 48rpx;
  font-weight: 600;
  color: var(--secondary);
}

.stat-label {
  font-family: var(--font-label);
  font-size: 20rpx;
  color: var(--on-surface-variant);
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

/* ===== Menu List ===== */
.menu-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-xxl);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-lg);
  background: var(--surface-container-lowest);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-ambient);
  transition: all 0.4s;
}

.menu-item:active {
  background: var(--surface-container);
}

.menu-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.menu-icon.primary {
  background: var(--primary-fixed);
  color: var(--primary);
}

.menu-icon.tertiary {
  background: var(--tertiary-fixed);
  color: var(--tertiary);
}

.menu-icon.outline {
  background: var(--surface-container);
  color: var(--outline);
}

.menu-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-title {
  font-family: var(--font-body);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

.menu-subtitle {
  font-family: var(--font-label);
  font-size: 20rpx;
  color: var(--on-surface-variant);
  opacity: 0.7;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.badge {
  background: var(--secondary-container);
  color: var(--on-secondary-container);
  font-family: var(--font-label);
  font-size: 20rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-full);
}

.arrow {
  font-size: 48rpx;
  color: var(--on-surface-variant);
  opacity: 0.3;
  transition: transform 0.3s;
}

.menu-item:active .arrow {
  transform: translateX(8rpx);
}

/* ===== Menu Grid Duo ===== */
.menu-grid-duo {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-md);
}

.menu-card {
  display: flex;
  flex-direction: column;
  padding: var(--spacing-lg);
  background: var(--surface-container-lowest);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-ambient);
  transition: all 0.4s;
}

.menu-card:active {
  background: var(--surface-container);
}

.card-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: var(--spacing-md);
  border-radius: var(--radius-md);
  background: var(--surface-container);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.card-icon.outline {
  color: var(--outline);
}

.card-title {
  font-family: var(--font-body);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 4rpx;
}

.card-subtitle {
  font-family: var(--font-label);
  font-size: 18rpx;
  color: var(--on-surface-variant);
  opacity: 0.6;
}

/* ===== Login Section ===== */
.login-section {
  margin-top: var(--spacing-xxl);
  padding: 0 var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
}

.login-btn {
  width: 100%;
  padding: var(--spacing-lg) var(--spacing-xl);
  background: var(--primary);
  color: var(--on-primary);
  border-radius: var(--radius-full);
  font-family: var(--font-label);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: var(--shadow-elevated);
  transition: opacity 0.3s;
}

.login-btn:active {
  opacity: 0.9;
}

.version-text {
  font-family: var(--font-label);
  font-size: 18rpx;
  color: var(--on-surface-variant);
  opacity: 0.4;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.version-section {
  margin-top: var(--spacing-xxl);
  padding: 0 var(--spacing-lg);
  text-align: center;
}

/* Action Icons */
.action-icon {
  font-size: 40rpx;
  color: var(--secondary-fixed);
  opacity: 0.8;
  margin-left: var(--spacing-md);
  transition: opacity 0.3s;
}

.action-icon:active {
  opacity: 1;
}
