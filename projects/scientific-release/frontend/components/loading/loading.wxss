/* components/loading/loading.wxss - 莲花绽放动画 */

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(74, 93, 78, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-container {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 莲花 */
.lotus {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  animation: lotus-rotate 8s linear infinite;
}

@keyframes lotus-rotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 花瓣 */
.petal {
  position: absolute;
  width: 40rpx;
  height: 60rpx;
  background: linear-gradient(180deg, #4A5D4E 0%, #8FA89E 100%);
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  transform-origin: center bottom;
  animation: petal-bloom 2s ease-out infinite;
  box-shadow: 0 4rpx 12rpx rgba(74, 93, 78, 0.5);
}

.petal::after {
  content: '';
  position: absolute;
  top: 10%;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 40rpx;
  background: linear-gradient(180deg, #C9B037 0%, transparent 100%);
  border-radius: 50%;
  opacity: 0.6;
}

/* 8 个花瓣位置 */
.petal-1 { bottom: 0; left: 50%; transform: translateX(-50%) rotate(0deg); animation-delay: 0s; }
.petal-2 { bottom: 0; left: 50%; transform: translateX(-50%) rotate(45deg); animation-delay: 0.1s; }
.petal-3 { bottom: 0; left: 50%; transform: translateX(-50%) rotate(90deg); animation-delay: 0.2s; }
.petal-4 { bottom: 0; left: 50%; transform: translateX(-50%) rotate(135deg); animation-delay: 0.3s; }
.petal-5 { bottom: 0; left: 50%; transform: translateX(-50%) rotate(180deg); animation-delay: 0.4s; }
.petal-6 { bottom: 0; left: 50%; transform: translateX(-50%) rotate(225deg); animation-delay: 0.5s; }
.petal-7 { bottom: 0; left: 50%; transform: translateX(-50%) rotate(270deg); animation-delay: 0.6s; }
.petal-8 { bottom: 0; left: 50%; transform: translateX(-50%) rotate(315deg); animation-delay: 0.7s; }

@keyframes petal-bloom {
  0%, 100% {
    transform: translateX(-50%) scale(0.8);
    opacity: 0.7;
  }
  50% {
    transform: translateX(-50%) scale(1.1);
    opacity: 1;
  }
}

/* 中心光晕 */
.lotus-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 40rpx;
  height: 40rpx;
  background: radial-gradient(circle, #C9B037 0%, #f4d03f 50%, transparent 70%);
  border-radius: 50%;
  animation: center-glow 1.5s ease-in-out infinite alternate;
  box-shadow: 0 0 20rpx rgba(201, 176, 55, 0.6);
}

@keyframes center-glow {
  0% {
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 0.6;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.2);
    opacity: 1;
  }
}

/* 加载文字 */
.loading-text {
  margin-top: 48rpx;
  color: #C9B037;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  animation: text-pulse 2s ease-in-out infinite;
}

@keyframes text-pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}
