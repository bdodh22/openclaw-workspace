/* components/lotus-loading/lotus-loading.wxss - 莲花绽放 loading 动画 */

.lotus-loading-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.lotus-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(74, 93, 78, 0.85);
  backdrop-filter: blur(8rpx);
}

.lotus-content {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 莲花花朵 */
.lotus-flower {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  animation: lotus-rotate 20s linear infinite;
}

@keyframes lotus-rotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 花瓣样式 */
.petal {
  position: absolute;
  width: 60rpx;
  height: 100rpx;
  background: linear-gradient(180deg, #C9B037 0%, #E5C55A 50%, #C9B037 100%);
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  transform-origin: center bottom;
  box-shadow: 0 4rpx 20rpx rgba(201, 176, 55, 0.6);
  animation: petal-bloom 2s ease-out forwards;
  opacity: 0;
}

.petal::before {
  content: '';
  position: absolute;
  top: 10%;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 60rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.4) 0%, transparent 100%);
  border-radius: 50%;
}

/* 8 个花瓣，每个旋转 45 度 */
.petal-1 { left: 50%; top: 0; transform: translateX(-50%) rotate(0deg); animation-delay: 0s; }
.petal-2 { left: 50%; top: 0; transform: translateX(-50%) rotate(45deg); animation-delay: 0.1s; }
.petal-3 { left: 50%; top: 0; transform: translateX(-50%) rotate(90deg); animation-delay: 0.2s; }
.petal-4 { left: 50%; top: 0; transform: translateX(-50%) rotate(135deg); animation-delay: 0.3s; }
.petal-5 { left: 50%; top: 0; transform: translateX(-50%) rotate(180deg); animation-delay: 0.4s; }
.petal-6 { left: 50%; top: 0; transform: translateX(-50%) rotate(225deg); animation-delay: 0.5s; }
.petal-7 { left: 50%; top: 0; transform: translateX(-50%) rotate(270deg); animation-delay: 0.6s; }
.petal-8 { left: 50%; top: 0; transform: translateX(-50%) rotate(315deg); animation-delay: 0.7s; }

@keyframes petal-bloom {
  0% {
    transform: translateX(-50%) rotate(var(--rotation)) scale(0.3) translateY(50rpx);
    opacity: 0;
  }
  50% {
    opacity: 1;
  }
  100% {
    transform: translateX(-50%) rotate(var(--rotation)) scale(1) translateY(0);
    opacity: 1;
  }
}

/* 莲花中心 */
.lotus-center {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.center-glow {
  position: absolute;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(201, 176, 55, 0.8) 0%, rgba(201, 176, 55, 0.2) 70%, transparent 100%);
  border-radius: 50%;
  animation: center-pulse 1.5s ease-in-out infinite;
}

@keyframes center-pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.3);
    opacity: 0.4;
  }
}

.loading-text {
  position: relative;
  z-index: 10;
  font-size: 26rpx;
  color: #C9B037;
  font-weight: 400;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(201, 176, 55, 0.5);
}

/* 涟漪效果 */
.ripple {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(201, 176, 55, 0.4);
  animation: ripple-expand 2s ease-out infinite;
  opacity: 0;
}

.ripple-1 {
  width: 100rpx;
  height: 100rpx;
  animation-delay: 0s;
}

.ripple-2 {
  width: 100rpx;
  height: 100rpx;
  animation-delay: 0.6s;
}

.ripple-3 {
  width: 100rpx;
  height: 100rpx;
  animation-delay: 1.2s;
}

@keyframes ripple-expand {
  0% {
    width: 0;
    height: 0;
    opacity: 1;
    border-width: 4rpx;
  }
  100% {
    width: 280rpx;
    height: 280rpx;
    opacity: 0;
    border-width: 0;
  }
}
