/* app.wxss - 全局样式变量和动画 */

/* ===== CSS 变量 ===== */
page {
  /* 色彩系统 */
  --primary-color: #4A5D4E;
  --accent-gold: #C9B037;
  --bg-primary: #EFEEE9;
  --bg-secondary: #F5F5F0;
  --bg-card: #FFFFFF;
  
  /* 文字颜色 */
  --text-primary: #2C2C2C;
  --text-secondary: #666666;
  --text-hint: #999999;
  
  /* 边框和阴影 */
  --border-color: rgba(74, 93, 78, 0.1);
  --shadow-soft: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-medium: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  
  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  
  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 9999rpx;
}

/* ===== 全局动画 ===== */

/* 页面转场动画 - 淡入 */
@keyframes pageFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.page-container {
  animation: pageFadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 页面转场动画 - 从右滑入 */
@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(100rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.page-slide-in {
  animation: slideInRight 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 页面转场动画 - 缩放进入 */
@keyframes zoomIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.page-zoom-in {
  animation: zoomIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 元素淡入动画 */
@keyframes elementFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.animate-fade-in {
  animation: elementFadeIn 0.5s ease-out forwards;
}

/* 元素从下向上浮动 */
@keyframes floatUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-float-up {
  animation: floatUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

/* 弹性动画 */
@keyframes bounceIn {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    opacity: 1;
    transform: scale(1.05);
  }
  70% {
    transform: scale(0.9);
  }
  100% {
    transform: scale(1);
  }
}

.animate-bounce-in {
  animation: bounceIn 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
}

/* 摇晃动画（错误提示） */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-10rpx); }
  20%, 40%, 60%, 80% { transform: translateX(10rpx); }
}

.animate-shake {
  animation: shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
}

/* 脉冲动画（强调） */
@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.05);
  }
}

.animate-pulse {
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

/* 旋转加载动画 */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

.animate-spin {
  animation: spin 1s linear infinite;
}

/* 延迟动画类 */
.animate-delay-1 { animation-delay: 0.1s; }
.animate-delay-2 { animation-delay: 0.2s; }
.animate-delay-3 { animation-delay: 0.3s; }
.animate-delay-4 { animation-delay: 0.4s; }

/* ===== 通用工具类 ===== */

/* 文本截断 */
.text-truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-truncate-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 烫金文字效果 */
.text-gold {
  background: linear-gradient(135deg, #C9B037 0%, #E5C55A 50%, #C9B037 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  background-size: 200% auto;
  animation: goldShimmer 3s linear infinite;
}

@keyframes goldShimmer {
  0% { background-position: 0% center; }
  100% { background-position: 200% center; }
}

/* 阴影效果 */
.shadow-soft {
  box-shadow: var(--shadow-soft);
}

.shadow-medium {
  box-shadow: var(--shadow-medium);
}

/* 渐变背景 */
.bg-gradient-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, #3A4A3E 100%);
}

.bg-gradient-gold {
  background: linear-gradient(135deg, #C9B037 0%, #B8945E 100%);
}

/* 灵活布局 */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}
