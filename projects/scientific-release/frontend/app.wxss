/* app.wxss - Global Styles - Modern Zen Design */

/* ===== 颜色系统 - 东方禅意配色 ===== */
page {
  /* 主色调 - 黛绿/青瓷色 */
  --primary-color: #4A5D4E;        /* 黛绿 - 沉稳内敛 */
  --primary-light: #6B7D6D;        /* 青瓷色 - 浅一层 */
  --primary-dark: #2D3A32;         /* 深黛绿 - 更深沉 */
  
  /* 辅助色 - 大地色系 */
  --accent-gold: #C9A961;          /* 暖沙金 - 尊贵点缀 */
  --accent-gold-light: #D4BC7E;    /* 浅金 - 高光 */
  
  /* 背景色 - 宣纸质感 */
  --bg-primary: #F9F8F4;           /* 米宣纸色 - 主背景 */
  --bg-card: #FFFFFF;              /* 纯白 - 卡片背景 */
  --bg-secondary: #F2F0E9;         /* 浅米色 - 次要背景 */
  
  /* 文字色 - 深岩灰 */
  --text-primary: #3D3D3D;         /* 深岩灰 - 主文字 */
  --text-secondary: #6B6B6B;       /* 中灰 - 次要文字 */
  --text-hint: #9A9A9A;            /* 浅灰 - 提示文字 */
  --text-gold: #C9A961;            /* 金色文字 */
  
  /* 功能色 */
  --success: #5D7A5F;              /* 成功色 - 低饱和绿 */
  --warning: #B8945E;              /* 警告色 - 土金色 */
  --error: #A86B6B;                /* 错误色 - 暗红 */
  
  /* 边框与阴影 */
  --border-color: #E8E6DF;         /* 浅米边框 */
  --shadow-soft: 0 4rpx 24rpx rgba(74, 93, 78, 0.08);
  --shadow-elevated: 0 8rpx 48rpx rgba(74, 93, 78, 0.12);
  --shadow-gold: 0 4rpx 24rpx rgba(201, 169, 97, 0.2);
  
  /* 字体设置 */
  font-family: 'PingFang SC', 'HarmonyOS Sans', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  background-color: var(--bg-primary);
  color: var(--text-primary);
  line-height: 1.8;
  letter-spacing: 0.5rpx;
}

/* ===== 容器与留白 ===== */
.container {
  padding: 32rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
}

/* ===== 卡片系统 - 液态玻璃拟态 ===== */
.card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-soft);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10rpx);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-elevated);
}

/* 金色边框卡片 - 用于强调 */
.card-gold {
  border: 1rpx solid var(--accent-gold);
  box-shadow: var(--shadow-gold);
}

/* ===== 按钮系统 - 有机形态 ===== */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 28rpx 56rpx;
  font-size: 30rpx;
  font-weight: 400;
  letter-spacing: 2rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(74, 93, 78, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.5s;
}

.btn-primary:active::before {
  left: 100%;
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(74, 93, 78, 0.2);
}

/* 金色按钮 - 用于强调操作 */
.btn-gold {
  background: linear-gradient(135deg, var(--accent-gold) 0%, #B8945E 100%);
  box-shadow: 0 8rpx 32rpx rgba(201, 169, 97, 0.4);
}

/* 幽灵按钮 - 次要操作 */
.btn-ghost {
  background: transparent;
  color: var(--primary-color);
  border: 1rpx solid var(--primary-color);
  box-shadow: none;
}

/* ===== 文字排版 - 新中式 ===== */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-hint {
  color: var(--text-hint);
}

.text-gold {
  color: var(--accent-gold);
  background: linear-gradient(135deg, var(--accent-gold) 0%, var(--accent-gold-light) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 标题样式 - 宋体风格 */
.title-large {
  font-size: 48rpx;
  font-weight: 300;
  letter-spacing: 4rpx;
  line-height: 1.4;
  color: var(--text-primary);
}

.title-medium {
  font-size: 36rpx;
  font-weight: 300;
  letter-spacing: 2rpx;
  line-height: 1.5;
}

.title-small {
  font-size: 28rpx;
  font-weight: 400;
  letter-spacing: 1rpx;
}

/* 禅语样式 */
.text-zen {
  font-size: 32rpx;
  font-weight: 300;
  line-height: 2;
  letter-spacing: 3rpx;
  color: var(--text-secondary);
  font-style: italic;
  text-align: center;
}

/* ===== 间距系统 ===== */
.spacing-xs { margin: 8rpx; }
.spacing-sm { margin: 16rpx; }
.spacing-md { margin: 24rpx; }
.spacing-lg { margin: 32rpx; }
.spacing-xl { margin: 48rpx; }

.padding-xs { padding: 8rpx; }
.padding-sm { padding: 16rpx; }
.padding-md { padding: 24rpx; }
.padding-lg { padding: 32rpx; }
.padding-xl { padding: 48rpx; }

/* ===== 分割线 - 留白式 ===== */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--border-color), transparent);
  margin: 48rpx 0;
}

/* ===== 加载动画 - 呼吸效果 ===== */
@keyframes breathe {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

.loading-dots {
  display: flex;
  gap: 8rpx;
  justify-content: center;
}

.loading-dots dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary-color);
  animation: breathe 1.5s ease-in-out infinite;
}

.loading-dots dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dots dot:nth-child(3) { animation-delay: 0.4s; }

/* ===== 涟漪动画 - 用于放生完成 ===== */
@keyframes ripple {
  0% {
    transform: scale(0);
    opacity: 1;
  }
  100% {
    transform: scale(4);
    opacity: 0;
  }
}

.ripple {
  position: fixed;
  width: 200rpx;
  height: 200rpx;
  border: 2rpx solid var(--accent-gold);
  border-radius: 50%;
  animation: ripple 1s ease-out forwards;
  pointer-events: none;
}

/* ===== 淡入动画 ===== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in {
  animation: fadeInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

/* ===== 工具类 ===== */
.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-column { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }

.text-center { text-align: center; }
.text-right { text-align: right; }

.mt-2 { margin-top: 16rpx; }
.mt-4 { margin-top: 32rpx; }
.mt-6 { margin-top: 48rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mb-6 { margin-bottom: 48rpx; }

/* ===== 隐藏滚动条但保留功能 ===== */
.hide-scrollbar::-webkit-scrollbar {
  display: none;
}

.hide-scrollbar {
  -ms-overflow-style: none;
  scrollbar-width: none;
}
