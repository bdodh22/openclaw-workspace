/* app.wxss - Stitch Design System: 现代东方禅意 */

/* ===== Design Tokens - From DESIGN.md ===== */
page {
  /* 色彩系统 - The "No-Line" Palette */
  --primary: #334537;
  --primary-container: #4A5D4E;
  --on-primary: #FFFFFF;
  --on-primary-fixed: #0E1F13;
  --on-primary-fixed-variant: #394B3D;
  --primary-fixed: #D3E8D5;
  --primary-fixed-dim: #B7CCB9;
  
  --secondary: #6E5E00;
  --secondary-container: #FEE264;
  --on-secondary: #FFFFFF;
  --on-secondary-fixed: #211B00;
  --on-secondary-fixed-variant: #534600;
  --secondary-fixed: #FEE264;
  --secondary-fixed-dim: #E0C64B;
  
  --tertiary: #533D20;
  --tertiary-container: #6D5435;
  --on-tertiary: #FFFFFF;
  --tertiary-fixed: #FFDDB6;
  --tertiary-fixed-dim: #E2C19B;
  
  /* 表面层级 - Surface Hierarchy (无框线原则) */
  --surface: #FAF9F4;              /* Level 0: Rice Paper Background */
  --surface-container: #EFEEE9;    /* Level 1: Sections */
  --surface-container-low: #F5F4EF; /* Level 1.5 */
  --surface-container-lowest: #FFFFFF; /* Level 2: Cards */
  --surface-container-high: #E9E8E3;
  --surface-container-highest: #E3E2DE;
  
  /* 文字颜色 */
  --on-surface: #1B1C19;           /* 墨黑 - 标题 */
  --on-surface-variant: #434843;   /* 正文 */
  --outline: #737872;
  --outline-variant: #C3C8C1;
  
  /* 错误色 */
  --error: #BA1A1A;
  --error-container: #FFDAD6;
  --on-error: #FFFFFF;
  
  /* 字体系统 - Editorial Voice */
  --font-headline: 'Noto Serif SC', 'Noto Serif', serif;
  --font-body: 'Plus Jakarta Sans', sans-serif;
  --font-label: 'Plus Jakarta Sans', sans-serif;
  
  /* 间距系统 - Asymmetrical Spacing */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 40rpx;
  --spacing-xxl: 48rpx;
  
  /* 圆角 - Weathered Stones */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 32rpx;
  --radius-xxl: 48rpx;
  --radius-full: 9999rpx;
  
  /* 阴影 - Ambient Light (非传统投影) */
  --shadow-ambient: 0 4rpx 20rpx rgba(27, 28, 25, 0.04);
  --shadow-elevated: 0 8rpx 32rpx rgba(27, 28, 25, 0.08);
  --shadow-floated: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
  --shadow-inset: inset 0 0 40rpx rgba(0, 0, 0, 0.02);
  
  /* 模糊 - Glassmorphism */
  --blur-glass: blur(20rpx);
  --blur-heavy: blur(40rpx);
}

/* ===== Global Typography ===== */
page {
  font-family: var(--font-body);
  background-color: var(--surface);
  color: var(--on-surface);
  line-height: 1.6;
}

/* 标题字体 - Serif (禅意) */
.headline {
  font-family: var(--font-headline);
  font-weight: 500;
  letter-spacing: 1rpx;
}

.headline-lg {
  font-size: 48rpx;
  line-height: 1.3;
}

.headline-md {
  font-size: 40rpx;
  line-height: 1.3;
}

.headline-sm {
  font-size: 32rpx;
  line-height: 1.4;
}

.headline-xs {
  font-size: 28rpx;
  line-height: 1.4;
}

/* 正文字体 - Sans-Serif (工具) */
.body-lg {
  font-size: 32rpx;
  line-height: 1.8;
}

.body-md {
  font-size: 28rpx;
  line-height: 1.7;
}

.body-sm {
  font-size: 24rpx;
  line-height: 1.6;
}

/* 标签字体 - Sans-Serif (元数据) */
.label-lg {
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.label-md {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 1.5rpx;
}

.label-sm {
  font-size: 18rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

/* =====烫金效果 - Gold Foil===== */
.gold-foil-text {
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-fixed) 50%, var(--secondary) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0rpx 1rpx 1rpx rgba(254, 226, 100, 0.2));
  background-size: 200% auto;
  animation: goldShimmer 3s linear infinite;
}

.gold-foil-bg {
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-fixed) 100%);
}

@keyframes goldShimmer {
  0% { background-position: 0% center; }
  100% { background-position: 200% center; }
}

/* =====水墨晕染背景 - Ink Wash===== */
.ink-wash-bg {
  background-image: 
    radial-gradient(circle at 20% 30%, rgba(74, 93, 78, 0.05) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(110, 94, 0, 0.03) 0%, transparent 40%);
}

/* =====宣纸纹理 - Rice Paper===== */
.rice-paper-texture {
  background-color: var(--surface);
  /* 可选：添加微妙的纸张纹理 */
}

/* =====无框线卡片 - No-Line Cards===== */
.card-surface {
  background: var(--surface-container-lowest);
  /* 仅通过色调差异定义边界，不使用 border */
}

.card-glass {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: var(--blur-glass);
  -webkit-backdrop-filter: var(--blur-glass);
}

/* =====圆形去底图片 - Circular Cutout===== */
.image-cutout {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 8rpx solid var(--surface-container-low);
  box-shadow: inset 0 8rpx 24rpx rgba(74, 93, 78, 0.1);
}

.image-cutout image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}

/* =====胶囊标签 - Capsule Tags===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  font-family: var(--font-label);
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.tag-native {
  background: var(--primary-fixed);
  color: var(--on-primary-fixed-variant);
}

.tag-prohibited {
  background: var(--error-container);
  color: var(--error);
}

.tag-gold {
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-fixed) 100%);
  color: var(--on-secondary-fixed);
}

/* =====底部导航 - Bottom Navigation===== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 140rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--surface);
  backdrop-filter: var(--blur-heavy);
  -webkit-backdrop-filter: var(--blur-heavy);
  border-radius: 48rpx 48rpx 0 0;
  box-shadow: var(--shadow-floated);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) var(--spacing-md);
  color: var(--on-surface-variant);
  opacity: 0.6;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.nav-item:active {
  transform: scale(0.95);
}

.nav-item.active {
  opacity: 1;
  background: var(--surface-container);
  border-radius: var(--radius-md);
}

.nav-item.active .nav-icon {
  font-variation-settings: 'FILL' 1;
}

.nav-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.nav-label {
  font-family: var(--font-label);
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.2;
}

/* =====顶部导航 - Top Navigation===== */
.top-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 112rpx;
  padding: 0 var(--spacing-lg);
  background: var(--primary-container);
  backdrop-filter: var(--blur-glass);
  -webkit-backdrop-filter: var(--blur-glass);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.nav-brand {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.brand-icon {
  font-size: 48rpx;
  color: var(--secondary-fixed);
}

.brand-title {
  font-family: var(--font-headline);
  font-size: 36rpx;
  font-weight: 600;
  color: var(--secondary-fixed);
  letter-spacing: 4rpx;
}

/* =====Bento Grid 布局===== */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-md);
}

.bento-large {
  grid-column: span 2;
}

/* =====动画系统 - Zen Transitions===== */
@keyframes breathe {
  0%, 100% { opacity: 0.3; transform: scale(0.9); }
  50% { opacity: 1; transform: scale(1.1); }
}

@keyframes floatUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.animate-breathe {
  animation: breathe 1.5s ease-in-out infinite;
}

.animate-float-up {
  animation: floatUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.animate-fade-in {
  animation: fadeIn 0.4s ease-out forwards;
}

/* =====工具类 - Utilities===== */
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.gap-xs { gap: var(--spacing-xs); }
.gap-sm { gap: var(--spacing-sm); }
.gap-md { gap: var(--spacing-md); }
.gap-lg { gap: var(--spacing-lg); }

/* =====安全区域 - Safe Area===== */
.safe-top {
  padding-top: env(safe-area-inset-top);
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* =====隐藏滚动条 - Hide Scrollbar===== */
.no-scrollbar::-webkit-scrollbar {
  display: none;
}

.no-scrollbar {
  -ms-overflow-style: none;
  scrollbar-width: none;
}
