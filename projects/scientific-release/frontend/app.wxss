/* app.wxss - Global Styles */

/* Color Variables */
page {
  --primary-color: #2E7D32;
  --primary-light: #4CAF50;
  --primary-dark: #1B5E20;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --background: #F5F5F5;
  --white: #FFFFFF;
  --border-color: #E0E0E0;
  --warning: #FF9800;
  --error: #F44336;
  --success: #4CAF50;
  
  font-size: 16px;
  background-color: var(--background);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* Elderly-friendly base styles */
.container {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background-color: var(--white);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background-color: var(--primary-color);
  color: var(--white);
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary:active {
  background-color: var(--primary-dark);
}

.text-primary {
  color: var(--primary-color);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-hint {
  color: var(--text-hint);
}

/* Large font for elderly users */
.text-large {
  font-size: 36rpx;
}

.text-huge {
  font-size: 44rpx;
}

/* Flex utilities */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* Spacing utilities */
.mt-2 {
  margin-top: 16rpx;
}

.mt-4 {
  margin-top: 32rpx;
}

.mb-2 {
  margin-bottom: 16rpx;
}

.mb-4 {
  margin-bottom: 32rpx;
}
